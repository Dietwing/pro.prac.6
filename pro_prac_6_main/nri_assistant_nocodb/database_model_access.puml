@startuml
title Database Model for Offline NRI Assistant

hide methods
hide circle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho
skinparam defaultTextAlignment left
skinparam class {
    BackgroundColor white
    BorderColor #B85450
    ArrowColor #666666
    FontSize 12
}

class "Users" as Users {
  id
  login
  role
  display_name
  email
  created_at
  status
}

class "Campaigns" as Campaigns {
  id
  title
  game_master_id
  setting_name
  ruleset_name
  start_date
  status
  description
}

class "Game_Sessions" as Sessions {
  id
  campaign_id
  session_number
  session_date
  title
  summary
  status
}

class "Player_Characters" as Characters {
  id
  campaign_id
  owner_user_id
  name
  race
  character_class
  level
  max_hp
  current_hp
  mana
  strength
  dexterity
  intelligence
  notes
}

class "NPCs" as Npcs {
  id
  campaign_id
  name
  npc_role
  max_hp
  current_hp
  armor_class
  initiative_bonus
  notes
}

class "Combat_Encounters" as Encounters {
  id
  session_id
  name
  location
  round_number
  status
  notes
}

class "Combat_Participants" as Participants {
  id
  encounter_id
  entity_type
  entity_id
  initiative
  current_hp
  temporary_hp
  is_active
  status_summary
}

class "Game_Actions" as Actions {
  id
  encounter_id
  participant_id
  action_type
  action_name
  target_type
  target_id
  action_result
  created_at
  notes
}

class "Dice_Rolls" as Rolls {
  id
  action_id
  actor_type
  actor_id
  dice_formula
  modifier
  result
  roll_purpose
  created_at
}

class "Status_Effects" as Effects {
  id
  participant_id
  effect_name
  effect_type
  duration_rounds
  source
  description
  is_active
}

class "Inventory_Items" as Inventory {
  id
  character_id
  item_name
  item_type
  quantity
  weight
  notes
}

class "Notes" as Notes {
  id
  campaign_id
  session_id
  related_type
  related_id
  title
  text
  created_at
}

Users ||--o{ Campaigns : game_master_id
Users ||--o{ Characters : owner_user_id

Campaigns ||--o{ Sessions : campaign_id
Campaigns ||--o{ Characters : campaign_id
Campaigns ||--o{ Npcs : campaign_id
Campaigns ||--o{ Notes : campaign_id

Sessions ||--o{ Encounters : session_id
Sessions ||--o{ Notes : session_id

Encounters ||--o{ Participants : encounter_id
Encounters ||--o{ Actions : encounter_id

Participants ||--o{ Actions : participant_id
Participants ||--o{ Effects : participant_id

Actions ||--o{ Rolls : action_id

Characters ||--o{ Inventory : character_id

Characters .. Participants : entity_id
Npcs .. Participants : entity_id

Characters .. Actions : target_id
Npcs .. Actions : target_id

@enduml